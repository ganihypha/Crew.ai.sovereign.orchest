# Sovereign Business Engine - Environment Variables
# ==================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# Supabase Database
SUPABASE_URL=https://lfohzibcsafqthupcvdg.supabase.co
SUPABASE_SERVICE_KEY=<your-supabase-service-key>

# LLM Provider (OpenAI)
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL_NAME=gpt-4o-mini

# Search (Serper.dev - required for web search tool)
SERPER_API_KEY=<your-serper-api-key>

# WhatsApp Bridge (Fonnte)
FONNTE_TOKEN=<your-fonnte-token>

# Sovereign Web Dashboard
SOVEREIGN_WEB_URL=https://sovereign-orchestrator.pages.dev
SOVEREIGN_AUTH_TOKEN=<your-jwt-token>

# CrewAI AMP (auto-configured when deployed via AMP)
# CREWAI_API_KEY=<auto-set-by-amp>

# LangChain Tracing (optional - for debugging)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=<your-langchain-api-key>
